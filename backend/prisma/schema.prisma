generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Users {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  mfaEnabled   Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Sessions[]
  devices      Device[]

  //Strava
  userAuthStrava UserAuthStrava?
  
}

model Sessions {
  id        String   @id @default(uuid())

  userId    String
  user      Users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId  String?
  device    Device?  @relation(fields: [deviceId], references: [id])

  tokenHash String   @unique

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  expiresAt DateTime
  revoked   Boolean  @default(false)
}

model Device {
  id              String   @id @default(uuid())

  userId          String
  user            Users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fingerprintHash String

  deviceName      String?

  trusted         Boolean  @default(false)
  trustedUntil    DateTime?

  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())

  sessions        Sessions[]
}

model UserAuthStrava {
  id               String   @id @default(uuid())
  userId           String   @unique 
  user             Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userStrava      UserStrava?
  stravaAthleteId  String   @unique 
  accessToken      String   @db.Text
  refreshToken     String   @db.Text
  
  expiresAt        Int      
  scope            String   
  
  updatedAt        DateTime @updatedAt
}

model UserStrava {
  id              Int      @id 
  userId          String   @unique
  stravaAuth      UserAuthStrava @relation(fields: [userId], references: [userId], onDelete: Cascade)
  
  firstname       String?
  lastname          String?
  profilePicture    String?  
  city              String?
  state             String?
  country           String?
  sex               String?
  
  syncedAt          DateTime @default(now()) 

  allTimeStats    StravaAllTimeStatsBike?
  yearlyStats     StravaYearlyStatsBike[]
  monthlyStats    StravaMonthlyStatsBike[]
  recentActivities StravaRecentActivityBike[]
}





//****************************
// Shema Data Strava
//******************************


model StravaAllTimeStatsBike {
  stravaAthleteId Int          @id @unique
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)
  
  totalDistance   Float        @default(0)
  totalElevation  Float        @default(0)
  totalCount      Int          @default(0)
  totalTime       Int          @default(0)
  updatedAt       DateTime     @updatedAt
}

model StravaYearlyStatsBike {
  id              String       @id @default(uuid())
  stravaAthleteId Int
  year            Int
  distance        Float
  elevation       Float
  count           Int
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)

  @@unique([stravaAthleteId, year])
}

model StravaMonthlyStatsBike {
  id              String       @id @default(uuid())
  stravaAthleteId Int
  year            Int
  month           Int
  distance        Float
  elevation       Float
  count           Int
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)

  @@unique([stravaAthleteId, year, month])
}

model StravaRecentActivityBike {
  id                 BigInt     @id
  stravaAthleteId    Int
  name               String
  distance           Float
  movingTime         Int
  elapsedTime        Int
  totalElevationGain Float
  type               String
  startDate          DateTime
  stravaProfile      UserStrava @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)
}
