generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String
  mfaEnabled      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  activities      Activity[]
  computedMetrics ComputedMetric[]
  devices         Device[]
  goals           Goal[]
  integrations    Integration[]
  personalRecords PersonalRecord[]
  plannedWorkouts PlannedWorkout[]
  sessions        Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  lastSeen  DateTime @updatedAt
  expiredAt DateTime
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id              String    @id @default(uuid())
  userId          String
  fingerprintHash String
  deviceName      String?
  trusted         Boolean   @default(false)
  trustedUntil    DateTime?
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id             String       @id @default(uuid())
  userId         String
  provider       String
  externalUserId String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  usersStrava    UsersStrava?

  @@unique([userId, provider])
}

model UsersStrava {
  id               String           @id @default(uuid())
  integrationId    String           @unique
  stravaAuth       String?          @unique
  firstname        String?
  lastname         String?
  profilePicture   String?
  city             String?
  state            String?
  country          String?
  sex              String?
  syncedAt         DateTime         @default(now())
  stravaActivities StravaActivity[]
  stravaStats      StravaStats[]
  integration      Integration      @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model StravaStats {
  id          String      @id @default(uuid())
  userId      String
  periodType  String
  periodStart DateTime?
  periodEnd   DateTime?
  distance    Float
  count       Int
  elevation   Float
  avgWatts    Float?
  maxWatts    Float?
  updatedAt   DateTime    @updatedAt
  userStrava  UsersStrava @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(uuid())
  userId    String

  idStrava  String?
  idUpload String? @unique

  startDate DateTime
  createdAt DateTime @default(now())

  uploadDetail UploadActivity? @relation(fields: [idUpload], references: [id])
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idStrava])
}
model StravaActivity {
  id                 String            @id @default(uuid())
  userStravaId       String
  name               String
  distance           Float
  avgWatts           Float?
  maxWatts           Float?
  weightedWatts      Float?
  kilojoules         Float?
  hasPower           Boolean
  avgHeartrate       Float?
  maxHeartrate       Float?
  avgCadence         Float?
  avgTemp            Float?
  elevHigh           Float?
  elevLow            Float?
  calories           Float?
  dataId             String?
  device             String?
  updatedAt          DateTime          @updatedAt
  movingTime         Int
  elapsedTime        Int
  totalElevationGain Float
  type               String
  startDate          DateTime
  storage            StorageMetadata[]
  userStrava         UsersStrava       @relation(fields: [userStravaId], references: [id])
}

model UploadActivity {
  id       String            @id @default(uuid())
  dataId   String
  activity Activity?
  storage  StorageMetadata[]
}

model StorageMetadata {
  id               String          @id @default(uuid())
  r2Key            String          @unique
  mimeType         String
  fileSize         Int
  createdAt        DateTime        @default(now())
  stravaActivityId String?
  uploadActivityId String?
  stravaActivity   StravaActivity? @relation(fields: [stravaActivityId], references: [id])
  uploadActivity   UploadActivity? @relation(fields: [uploadActivityId], references: [id])
}

model PlannedWorkout {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  type        String
  duration    Int?
  distance    Float?
  intensity   String?
  startDate   DateTime
  startTime   String?
  isRecurring Boolean   @default(false)
  rrule       String?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id        String       @id @default(uuid())
  userId    String
  name      String
  type      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets   GoalTarget[]
}

model GoalTarget {
  id          String @id @default(uuid())
  goalId      String
  metricId    String
  targetValue Float
  goal        Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  metric      Metric @relation(fields: [metricId], references: [id])
}

model Metric {
  id              String           @id @default(uuid())
  key             String           @unique
  name            String
  unit            String
  aggregationType String?
  scope           String?
  computedMetrics ComputedMetric[]
  goalTargets     GoalTarget[]
  personalRecords PersonalRecord[]
}

model ComputedMetric {
  id        String   @id @default(uuid())
  userId    String
  metricKey String
  value     Float
  period    String
  updatedAt DateTime @updatedAt
  metric    Metric   @relation(fields: [metricKey], references: [key])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalRecord {
  id                String   @id @default(uuid())
  userId            String
  metricId          String
  value             Float
  achievedAt        DateTime
  period            String?
  sourceType        String?
  isManualValidated Boolean  @default(false)
  metric            Metric   @relation(fields: [metricId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookStrava {
  id               String   @id @default(uuid())
  userStravaId     String
  stravaActivityId String?
  aspectType       String
  rawPayload       Json
  status           String
  createdAt        DateTime @default(now())
}
