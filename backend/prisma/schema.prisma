generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Users {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  mfaEnabled   Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Sessions[]
  devices      Device[]

  //Objectif
  goals        Goal[]
  computedMetrics ComputedMetric[]

  //Strava
  userAuthStrava UserAuthStrava?

  //Planning
  plannedWorkout PlannedWorkout[]
  
}

model Sessions {
  id        String   @id @default(uuid())

  userId    String
  user      Users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId  String?
  device    Device?  @relation(fields: [deviceId], references: [id])

  tokenHash String   @unique

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  expiresAt DateTime
  revoked   Boolean  @default(false)
}

model Device {
  id              String   @id @default(uuid())

  userId          String
  user            Users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fingerprintHash String

  deviceName      String?

  trusted         Boolean  @default(false)
  trustedUntil    DateTime?

  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())

  sessions        Sessions[]
}

model UserAuthStrava {
  id               String   @id @default(uuid())
  userId           String   @unique 
  user             Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userStrava      UserStrava?
  stravaAthleteId  String   @unique 
  accessToken      String   @db.Text
  refreshToken     String   @db.Text
  
  expiresAt        Int      
  scope            String   
  
  updatedAt        DateTime @updatedAt
}

model UserStrava {
  id              Int      @id 
  userId          String   @unique
  stravaAuth      UserAuthStrava @relation(fields: [userId], references: [userId], onDelete: Cascade)
  
  firstname       String?
  lastname          String?
  profilePicture    String?  
  city              String?
  state             String?
  country           String?
  sex               String?
  
  syncedAt          DateTime @default(now()) 


  recordsStats StravaRecord?
  allTimeStats    StravaAllTimeStatsBike?
  yearlyStats     StravaYearlyStatsBike[]
  monthlyStats    StravaMonthlyStatsBike[]
  recentActivities StravaRecentActivityBike[]
}





//****************************
// Shema Data Strava
//******************************

model StravaRecord {
  stravaAthleteId Int          @id @unique
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)

  maxDistance   Float  @default(0)
  maxElevation  Float  @default(0)

  maxWatts      Int    @default(0)
  maxHeartrate  Int    @default(0)
  maxCadence    Float  @default(0)
  
  updatedAt     DateTime @updatedAt
}


model StravaAllTimeStatsBike {
  stravaAthleteId Int          @id @unique
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)
  
  totalDistance   Float        @default(0)
  totalElevation  Float        @default(0)
  totalCount      Int          @default(0)
  totalTime       Int          @default(0)
  updatedAt       DateTime     @updatedAt
}

model StravaYearlyStatsBike {
  id              String       @id @default(uuid())
  stravaAthleteId Int
  year            Int
  distance        Float
  elevation       Float
  count           Int
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)

  @@unique([stravaAthleteId, year])
}

model StravaMonthlyStatsBike {
  id              String       @id @default(uuid())
  stravaAthleteId Int
  year            Int
  month           Int
  distance        Float
  elevation       Float
  count           Int
  stravaProfile   UserStrava   @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)

  @@unique([stravaAthleteId, year, month])
}

model StravaRecentActivityBike {
  id                 BigInt     @id
  stravaAthleteId    Int
  name               String
  distance           Float
  movingTime         Int
  elapsedTime        Int
  totalElevationGain Float
  type               String
  startDate          DateTime
  stravaProfile      UserStrava @relation(fields: [stravaAthleteId], references: [id], onDelete: Cascade)

  details            StravaActivityDetail?
}


model StravaActivityDetail {
  id                 BigInt                  @id
  // Relation 1-1 avec l'activité parente
  activityId         BigInt                  @unique
  activity           StravaRecentActivityBike @relation(fields: [activityId], references: [id], onDelete: Cascade)
  avgWatts           Float?
  maxWatts           Int?
  weightedWatts      Float?   // Normalized Power
  kilojoules         Float?   // Énergie
  hasPower           Boolean  @default(false)

  avgHeartrate       Float?
  maxHeartrate       Int?

  avgCadence         Float?
  avgTemp            Int?
  elevHigh           Float?
  elevLow            Float?
  calories           Float?
  
  polyline           String?  @db.Text
  
  device             String?  // Ex: "Garmin Edge 830"
  updatedAt          DateTime @updatedAt
}

//****************************
// Shema Planning entrainement
//******************************


model PlannedWorkout {
  id              String   @id @default(cuid())
  userId          String 
  title           String
  description     String?
  type            String   
  duration        Int?     @default(0)
  distance        Float?   
  intensity       String?  
  
  // Gestion du temps
  startDate       DateTime 
  startTime       String? 
  
  // Récurrence (Optionnel)
  isRecurring     Boolean  @default(false)
  rrule           String?  
  endDate         DateTime? 

  createdAt       DateTime @default(now())
  user            Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}



//****************************
// Shema objectif 
//******************************

model Goal {
  id          String   @id @default(cuid())
  userId      String

  name        String?  // ex: "200km ride"
  type        String   // endurance, power, volume, custom

  startDate   DateTime @default(now())
  endDate     DateTime?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  user        Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  targets     GoalTarget[]

  @@index([userId, isActive])
}



model Metric {
  id    String @id @default(cuid())
  key   String @unique // "longest_ride", "weekly_distance", "ftp"

  unit  String         // "km", "watts"

  aggregationType String // max, sum, avg
  scope           String // activity, week, month, all_time

  targets GoalTarget[]
}


model GoalTarget {
  id          String @id @default(cuid())

  goalId      String
  metricId    String

  targetValue Float

  goal        Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  metric      Metric @relation(fields: [metricId], references: [id])

  @@index([goalId])
}


model ComputedMetric {
  id         String   @id @default(cuid())
  userId     String

  metricKey  String   // ex: "longest_ride"
  value      Float

  period     String   // all_time, week, month, etc.

  updatedAt  DateTime @updatedAt

  user       Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metricKey, period])
  @@index([userId, metricKey])
}